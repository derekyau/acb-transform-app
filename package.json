{
  "name": "acb-transform",
  "version": "1.0.0",
  "description": "ACB Transform desktop app for broker CSV files.",
  "author": "Derek Yau (derek.yau@gmail.com)",
  "main": "dist/main/main.js",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on http://127.0.0.1:5173 dist/main/main.js dist/main/preload.js && nodemon --watch dist/main --ext js,json --delay 200ms --exec \"cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run dist:mac",
    "dist:mac": "npm run build && electron-builder --mac -c.mac.identity=- -c.mac.hardenedRuntime=false",
    "dist:win": "npm run build && electron-builder --win",
    "lint": "eslint .",
    "test": "vitest run src --passWithNoTests",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "build": {
    "appId": "com.acbtransform.app",
    "productName": "ACB Transform",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "icon": "resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "eslint": "10.5.0",
    "nodemon": "^3.1.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "9.0.10"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
